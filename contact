<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact | Emmanuel "Manny" Camacho</title>
  <meta
    name="description"
    content="Connect with Emmanuel 'Manny' Camacho, Realtor in Kyle, Texas."
  />

  <style>
    :root {
      --emerald: #065f46;
      --emerald-soft: rgba(6,95,70,.12);
      --bg: #ffffff;
      --panel: #ffffff;
      --text: #111111;
      --muted: rgba(17,17,17,.72);
      --border: rgba(17,17,17,.12);
      --header-bg: #000000;
      --header-text: #ffffff;
      --maxw: 1240px;
    }

    html, body {
      margin: 0;
      padding: 0;
      width: 100%;
      max-width: 100%;
      overflow-x: hidden;
    }

    body {
      font-family: "Hedvig Letters Serif", serif;
      background: var(--bg);
      color: var(--text);
    }

    *, *::before, *::after {
      box-sizing: border-box;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    img {
      max-width: 100%;
      display: block;
      height: auto;
    }

    .site-header {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      width: 100%;
      background: var(--header-bg);
      z-index: 9999;
      border-bottom: 1px solid rgba(255,255,255,.1);
      transition: padding 0.25s ease, min-height 0.25s ease, box-shadow 0.25s ease;
    }

    .topbar {
      position: relative;
      min-height: 90px;
      padding: 0;
      transition: min-height 0.25s ease, padding 0.25s ease, gap 0.25s ease;
    }

    .top-link,
    .top-id,
    .logo-wrap,
    .logo-mini {
      transition: all 0.25s ease;
    }

    .logo-wrap {
      position: absolute;
      top: -14px;
      left: -8px;
      margin: 0;
      text-align: left;
      z-index: 2;
    }

    .top-link {
      position: absolute;
      bottom: 6px;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: flex-end;
      gap: 0;
    }

    .header-action {
      display: inline-flex;
      flex-direction: column;
      align-items: center;
      justify-content: flex-end;
      margin: 0;
      padding: 0;
      line-height: 1;
      text-decoration: none;
      margin-right: -22px;
    }

    .header-action:last-child {
      margin-right: 0;
    }

    .action-icon {
      display: block;
      height: auto;
      margin: 0;
      padding: 0;
    }

    .action-label {
      margin-top: -8px;
      font-family: "Hedvig Letters Serif", serif;
      font-size: 12px;
      font-weight: 600;
      line-height: 1;
      color: #fff;
      text-align: center;
    }

    .connect-btn { width: 90px; }
    .match-btn { width: 80px; }
    .data-btn { width: 82px; }

    .top-id {
      margin-left: auto;
      padding-top: 8px;
      padding-right: 14px;
      text-align: right;
      font-size: 14px;
      line-height: 1.4;
      color: #fff;
    }

    .logo-mini {
      display: inline-flex;
      flex-direction: column;
      align-items: flex-start;
      width: 132px;
      text-decoration: none;
      color: inherit;
    }

    .logo-mini:hover { opacity: 0.85; }

    .logo-mini img {
      display: block;
      width: 100%;
      height: auto;
      transform: translateX(-15px);
    }

    .logo-mini-label {
      position: static;
      transform: none;
      margin-top: -18px;
      margin-left: 8px;
      font-size: 10px;
      font-weight: 700;
      color: rgba(255,255,255,.8);
      white-space: nowrap;
      text-align: left;
      line-height: 1;
      transition: opacity 0.25s ease, transform 0.25s ease;
    }

    .site-header.shrink .logo-mini-label {
      opacity: 0;
      transform: translateY(-6px);
      pointer-events: none;
    }

    .site-header.shrink .topbar {
      min-height: 78px;
    }

    .site-header.shrink .top-link,
    .site-header.shrink .top-id {
      opacity: 0;
      pointer-events: none;
      max-height: 0;
      overflow: hidden;
      transform: translateY(-8px);
    }

    .page-wrap {
      width: 100%;
      margin: 0;
      padding: 190px 20px 32px;
      background: var(--bg);
    }

    .content-shell {
      max-width: 900px;
      margin: 0 auto;
    }

    .page-top-meta {
      margin-bottom: 24px;
    }

    .back-link {
      display: inline-block;
      font-size: 13px;
      text-decoration: underline;
      margin-bottom: 8px;
      color: var(--text);
    }

    .section-block {
      margin-bottom: 18px;
    }

    .panel {
      border: 1px solid var(--border);
      background: var(--panel);
      padding: 24px;
    }

    .contact-hero h1 {
      margin: 0 0 10px;
      font-size: 32px;
      font-weight: 600;
      line-height: 1.15;
      color: var(--text);
    }

    .contact-hero p {
      margin: 0;
      font-size: 15px;
      line-height: 1.7;
      color: var(--muted);
    }

    .contact-card {
      text-align: center;
      padding: 26px 24px;
    }

    .contact-name {
      margin: 0 0 8px;
      font-size: 28px;
      line-height: 1.2;
      color: var(--text);
    }

    .contact-role {
      margin: 0 0 16px;
      font-size: 15px;
      line-height: 1.6;
      color: var(--muted);
    }

    .contact-direct a {
      display: block;
      margin-bottom: 8px;
      font-size: 16px;
      text-decoration: underline;
      color: var(--text);
    }

    .contact-form-wrap h2 {
      margin: 0 0 16px;
      font-size: 22px;
      color: var(--text);
    }

    .contact-form-wrap p {
      margin: 0 0 20px;
      font-size: 14px;
      line-height: 1.7;
      color: var(--muted);
    }

    .contact-form {
      display: grid;
      gap: 16px;
    }

    .form-row {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 16px;
    }

    .form-group {
      display: flex;
      flex-direction: column;
    }

    .form-group label {
      font-size: 13px;
      margin-bottom: 8px;
      color: var(--text);
    }

    .form-group input,
    .form-group textarea {
      width: 100%;
      padding: 12px 14px;
      border: 1px solid var(--border);
      background: #fff;
      color: var(--text);
      font-family: inherit;
      font-size: 15px;
    }

    .form-group textarea {
      min-height: 160px;
      resize: vertical;
    }

    .consent-wrap {
      font-size: 13px;
      line-height: 1.7;
      color: var(--muted);
    }

    .consent-wrap label {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      cursor: pointer;
    }

    .consent-wrap input[type="checkbox"] {
      margin-top: 4px;
    }

    .submit-wrap {
      text-align: left;
    }

    .submit-btn {
      display: inline-block;
      padding: 12px 18px;
      border: 1px solid rgba(17,17,17,.22);
      background: #fff;
      color: var(--text);
      font-family: inherit;
      font-size: 14px;
      cursor: pointer;
    }

    .submit-btn:hover {
      border-color: rgba(17,17,17,.4);
    }

    .site-footer {
      border-top: 1px solid var(--border);
      background: #fff;
      color: var(--text);
    }

    .footer-shell {
      max-width: var(--maxw);
      margin: 0 auto;
      padding: 32px 20px;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 28px;
    }

    .footer-col {
      font-size: 14px;
      line-height: 1.7;
      color: var(--muted);
    }

    .footer-col a {
      display: block;
      margin-bottom: 6px;
      text-decoration: underline;
      color: var(--muted);
    }

    .footer-title {
      font-size: 13px;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 10px;
      color: var(--text);
    }

    .footer-bottom {
      margin-top: 24px;
      padding-top: 14px;
      border-top: 1px solid var(--border);
      font-size: 12px;
      color: var(--muted);
    }

    @media (max-width: 900px) {
      .footer-grid,
      .form-row {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 768px) {
      .topbar {
        min-height: 140px;
        padding: 0 10px;
      }

      .logo-wrap {
        position: absolute;
        top: -4px;
        left: 0;
      }

      .top-link {
        position: absolute;
        bottom: 10px;
        left: 50%;
        transform: translateX(-50%);
      }

      .top-id {
        position: absolute;
        top: 8px;
        right: 6px;
        text-align: right;
        font-size: 10px;
        line-height: 1.2;
        max-width: 145px;
        padding-right: 0;
      }

      .page-wrap {
        padding: 190px 14px 24px;
      }

      .contact-hero h1,
      .contact-name {
        font-size: 25px;
      }
    }
  </style>
</head>
<body>
  <header class="site-header" id="siteHeader">
    <div class="topbar">
      <div class="logo-wrap">
        <a href="/kyle-housing-site/" class="logo-mini">
          <img src="/kyle-housing-site/images/logo.png" alt="Your Missing Peace" />
          <span class="logo-mini-label">Your Missing Peace</span>
        </a>
      </div>

      <div class="top-link">
        <a href="/kyle-housing-site/match" class="header-action match-action">
          <img src="/kyle-housing-site/images/match2.png" alt="Match" class="action-icon match-btn">
          <span class="action-label">Match</span>
        </a>

        <a href="/kyle-housing-site/contact" class="header-action connect-action">
          <img src="/kyle-housing-site/images/connect2.png" alt="Connect" class="action-icon connect-btn">
          <span class="action-label">Connect</span>
        </a>

        <a href="/kyle-housing-site/data" class="header-action data-action">
          <img src="/kyle-housing-site/images/graph.png" alt="Data" class="action-icon data-btn">
          <span class="action-label">Data</span>
        </a>
      </div>

      <div class="top-id">
        <div>Realtor® in Kyle, TX</div>
        <div>Emmanuel "Manny" Camacho</div>
        <div>Dalton Wade Real Estate Group</div>
      </div>
    </div>
  </header>

  <main class="page-wrap">
    <div class="content-shell">
      <div class="page-top-meta">
        <a href="/kyle-housing-site/" class="back-link">&larr; Back to Home</a>
      </div>

      <section class="section-block">
        <div class="panel contact-hero">
          <h1>Connect</h1>
          <p>
            If you have questions about buying, selling, or simply want help making sense
            of the Kyle market, reach out below.
          </p>
        </div>
      </section>

      <section class="section-block">
        <div class="panel contact-card">
          <h2 class="contact-name">Emmanuel "Manny" Camacho</h2>
          <p class="contact-role">
            Realtor® in Kyle, TX<br>
            Dalton Wade Real Estate Group
          </p>

          <div class="contact-direct">
            <a href="tel:YOUR-NUMBER-HERE">YOUR PHONE NUMBER</a>
            <a href="mailto:YOUR-EMAIL-HERE">YOUR EMAIL</a>
          </div>
        </div>
      </section>

      <section class="section-block">
        <div class="panel contact-form-wrap">
          <h2>Send a Message</h2>
          <p>
            Fill out the form below and I’ll get back to you as soon as I can.
          </p>

          <!-- IMPORTANT:
               This plain HTML form layout will display on GitHub Pages,
               but you need a real form handler to receive submissions.
               For now, replace the action with Formspree or another service.
          -->
          <form
            class="contact-form"
            method="post"
            action="https://formspree.io/f/YOUR_FORM_ID"
          >
            <div class="form-row">
              <div class="form-group">
                <label for="name">Name</label>
                <input id="name" name="name" type="text" required>
              </div>

              <div class="form-group">
                <label for="email">Email</label>
                <input id="email" name="email" type="email">
              </div>

              <div class="form-group">
                <label for="phone">Phone</label>
                <input id="phone" name="phone" type="tel">
              </div>
            </div>

            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message"></textarea>
            </div>

            <div class="consent-wrap">
              <label for="consent">
                <input id="consent" name="consent" type="checkbox" required>
                <span>
                  By submitting this form, you consent to the collection, storage, and use
                  of your personal information as described in the Privacy Policy.
                </span>
              </label>
            </div>

            <div class="submit-wrap">
              <button class="submit-btn" type="submit">Send Message</button>
            </div>
          </form>
        </div>
      </section>
    </div>
  </main>

  <footer class="site-footer">
    <div class="footer-shell">
      <div class="footer-grid">
        <div class="footer-col">
          <div class="footer-title">Kyle Housing</div>
          <p>
            Local housing insight designed to bring clarity to pricing,
            neighborhoods, and decision-making in Kyle, Texas.
          </p>
        </div>

        <div class="footer-col">
          <div class="footer-title">Explore</div>
          <a href="/kyle-housing-site/">Home</a>
          <a href="/kyle-housing-site/data">Data Page</a>
          <a href="/kyle-housing-site/contact">Connect</a>
        </div>

        <div class="footer-col">
          <div class="footer-title">About</div>
          <p>
            Emmanuel "Manny" Camacho<br />
            Realtor® in Kyle, TX<br />
            Dalton Wade Real Estate Group
          </p>
        </div>
      </div>

      <div class="footer-bottom">
        <span>© 2026 Kyle Housing</span>
      </div>
    </div>
  </footer>

  <script>
    (function () {
      const siteHeader = document.getElementById("siteHeader");
      if (!siteHeader) return;

      function handleHeaderShrink() {
        if (window.scrollY > 80) {
          siteHeader.classList.add("shrink");
        } else {
          siteHeader.classList.remove("shrink");
        }
      }

      window.addEventListener("scroll", handleHeaderShrink, { passive: true });
      window.addEventListener("load", handleHeaderShrink);
      handleHeaderShrink();
    })();
  </script>
</body>
</html>
